APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/email_signatures

# Brand identity
BRAND_PRIMARY_COLOR=#000000
BRAND_SECONDARY_COLOR=#D14954
BRAND_COMPANY_NAME=BT Blue Ativos Judiciais
BRAND_LOGO_URL=https://www.btcreditos.com.br/wp-content/uploads/2024/10/cropped-BT_CREDITOS_SIMBOLO_01-300x300.png
#BRAND_WEBSITE_URL=https://btblue.com.br

# Observability — uncomment to write logs to a rotating file
#LOG_FILE=logs/app.log
