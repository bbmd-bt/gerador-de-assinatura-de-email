APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Never commit real credentials — use a secrets manager in production
DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname

# Brand identity — customize per deployment
BRAND_PRIMARY_COLOR=#000000
BRAND_SECONDARY_COLOR=#D14954
BRAND_COMPANY_NAME=Empresa S.A.
BRAND_LOGO_URL=https://cdn.example.com/logo.png
BRAND_WEBSITE_URL=https://example.com

# Observability — leave unset to log to stdout only
#LOG_FILE=logs/app.log
